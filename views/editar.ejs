<%- include("./partials/header.ejs")%>
<body>
    <nav class="navbar navbar-dark bg-primary">
        <div class="container">
        <a class="navbar-brand" href="/">
        <i class="bi bi-person-lines-fill"></i>
        </a>
        </div>
    </nav>
    <div class="container mt-5">
        <h2>Editar Contacto</h2>
        <form action="/actualizar/<%= contacto._id %>" method="POST">
        <div class="mb-3">
            <label>Nombre</label>
            <input
            type="text"
            name="nombre"
            class="form-control"
            value="<%= contacto.nombre %>"
            required>
        </div>
        <div class="mb-3">
            <label>Apellido</label>
            <input
            type="text"
            name="apellido"
            class="form-control"
            value="<%= contacto.apellido %>"
            required>
        </div>
        <div class="mb-3">
            <label>Correo</label>
            <input
            type="email"
            name="correo"
            class="form-control"
            value="<%= contacto.correo %>"
            required>
        </div>
        <div class="mb-3">
            <label>Tipo de Sangre</label>
            <select
            name="tipoSangre"
            class="form-control">
            <option <%= contacto.tipoSangre=="O+"?"selected":"" %>>O+</option>
            <option <%= contacto.tipoSangre=="O-"?"selected":"" %>>O-</option>
            <option <%= contacto.tipoSangre=="A+"?"selected":"" %>>A+</option>
            <option <%= contacto.tipoSangre=="A-"?"selected":"" %>>A-</option>
            <option <%= contacto.tipoSangre=="B+"?"selected":"" %>>B+</option>
            <option <%= contacto.tipoSangre=="B-"?"selected":"" %>>B-</option>
            <option <%= contacto.tipoSangre=="AB+"?"selected":"" %>>AB+</option>
            <option <%= contacto.tipoSangre=="AB-"?"selected":"" %>>AB-</option>
            </select>
        </div>
        <div class="mb-3">
            <label>Cédula</label>
            <input
            type="text"
            name="cedula"
            class="form-control"
            value="<%= contacto.cedula %>"
            required>
        </div>
        <div class="mb-3">
            <label>Fecha de nacimiento</label>
            <input
            type="date"
            name="fechaNacimiento"
            class="form-control"
            value="<%= contacto.fechaNacimiento.toISOString().substring(0,10) %>"
            required>
        </div>
            <button class="btn btn-primary">
            Actualizar
            </button>
            <a href="/" class="btn btn-secondary">
            Cancelar
            </a>
            </form>
    </div>
    <%- include("./partials/footer.ejs")%>
</body>
</html>